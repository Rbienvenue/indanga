{
  "$schema": "https://v2-9-14.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "build/**",
        ".next/**",
      ],
    },
    "dev": {
      "cache": false,
      "dependsOn": ["^dev"],
      "persistent": true
    }
  }
}
